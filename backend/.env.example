# Required: MongoDB connection used by FastAPI and startup seeding.
MONGO_URL=mongodb://127.0.0.1:27017

# Required: database name used by DialBox.
DB_NAME=dialbox

# Required in production: comma-separated frontend origins.
# Example: https://dialbox.example.com,https://www.dialbox.example.com
CORS_ORIGINS=http://127.0.0.1:3000

# Required by the public production entry point to protect configuration writes.
# Generate a long random value and send it only as X-DialBox-Admin-Key.
ADMIN_API_KEY=

# Optional for core startup. Required by paid AI and text-to-speech features.
EMERGENT_LLM_KEY=
