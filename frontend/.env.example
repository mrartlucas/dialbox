# Required at build time. Use the backend origin without a trailing /api.
REACT_APP_BACKEND_URL=http://127.0.0.1:8000

# Production builds hide the configuration panel and DTMF development lab by default.
# Set true only for a controlled internal build.
REACT_APP_ENABLE_DEV_TOOLS=false

# Optional development-only webpack health endpoints.
ENABLE_HEALTH_CHECK=false
